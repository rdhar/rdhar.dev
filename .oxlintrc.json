{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc", "import", "jsx-a11y"],
  "categories": {
    "correctness": "error"
  },
  "rules": {
    "typescript/triple-slash-reference": "off"
  },
  "ignorePatterns": [
    ".astro/**",
    ".github/**",
    ".vscode/**",
    "dist/**",
    "node_modules/**",
    "public/**"
  ]
}
